# ── Claude OS — Environment Variables ────────────────────────────────────────
# Copy to .env.local and fill in your values

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-string

# One-time seed key to create the admin user via POST /api/auth/seed
SEED_KEY=your-seed-key-here

# Ollama / Hermes settings
OLLAMA_BASE_URL=http://localhost:11434/v1
HERMES_MODEL=nous-hermes2

# Optional: custom path for the SQLite database file
# DB_PATH=/var/lib/claude-os

# Optional: directory agents can read/write files to
# AGENT_FILES_DIR=/var/lib/claude-os/agent-files
