# ── Claude OS — Environment Variables ────────────────────────────────────────
# Copy this file to .env.local on your VPS and fill in your values

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# Model to use (gpt-4o-mini is fast + cheap, gpt-4o is smarter)
OPENAI_MODEL=gpt-4o-mini

# Optional: override base URL (leave as-is for standard OpenAI)
OPENAI_BASE_URL=https://api.openai.com/v1

# JWT secret — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-string

# One-time key to create your admin account via /api/auth/seed
SEED_KEY=pick-any-secret-word

# Optional: custom SQLite path (default: ./data/claude-os.db)
# DB_PATH=/var/lib/claude-os

# Optional: directory agents can read/write files to
# AGENT_FILES_DIR=/var/lib/claude-os/agent-files
